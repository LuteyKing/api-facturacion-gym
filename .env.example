# ═══════════════════════════════════════════════════════════
# Microservicio de Facturación Electrónica SRI — Ecuador
# ═══════════════════════════════════════════════════════════
# Copie este archivo a .env y complete con sus datos reales.
# NUNCA suba el .env al repositorio (está en .gitignore).
# ═══════════════════════════════════════════════════════════

# ── Entorno SRI ──────────────────────────────────────────
# 1 = Pruebas (celcer.sri.gob.ec)
# 2 = Producción (cel.sri.gob.ec)
SRI_AMBIENTE=1
SRI_TIPO_EMISION=1

# ── Datos del emisor ────────────────────────────────────
# Complete con los datos reales de su empresa/negocio.
EMISOR_RUC=0000000000001
EMISOR_RAZON_SOCIAL=MI EMPRESA S.A.
EMISOR_NOMBRE_COMERCIAL=MI EMPRESA
EMISOR_DIR_MATRIZ=Av. Principal y Calle Secundaria - Ciudad
EMISOR_DIR_ESTABLECIMIENTO=Av. Principal y Calle Secundaria - Ciudad
EMISOR_OBLIGADO_CONTABILIDAD=NO
EMISOR_CONTRIBUYENTE_ESPECIAL=

# ── Establecimiento y punto de emisión ──────────────────
# Códigos de 3 dígitos asignados por el SRI.
EMISOR_ESTABLECIMIENTO=001
EMISOR_PUNTO_EMISION=001

# ── Firma electrónica (.p12) ─────────────────────────────
# Nombre del archivo .p12 — debe estar en la carpeta certificados/
# Obtenga su firma digital en: https://www.securitydata.net.ec
#                               https://www.anfac.com.ec
FIRMA_ELECTRONICA_ARCHIVO=firma.p12
FIRMA_ELECTRONICA_PASSWORD=su_clave_de_firma
